@model List<PATBMS_Web.Models.Notification>

@{
    ViewData["Title"] = "Notifications";
    var currentUserID = ViewBag.CurrentUserID as string;
}

@await Html.PartialAsync("_BackButton")

<div class="page-header">
    <div class="page-title">System Notifications</div>
    <div class="page-subtitle">
        Capacity alerts and system events
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card">
    <div class="card-header">
        Notifications
        <span style="float: right; color: var(--text-secondary); font-size: 12px;">
            @Model.Count(n => n.AcknowledgedBy != currentUserID && 
                              !n.IsAcknowledged) unacknowledged
        </span>
    </div>

    @if (Model.Count == 0)
    {
        <p style="color: var(--text-secondary); padding: 16px 0;">
            No notifications yet.
        </p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Message</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var n in Model)
                {
                    var acknowledgedByMe = n.AcknowledgedBy == currentUserID;
                    
                    <tr style="@(acknowledgedByMe ? "opacity: 0.5;" : "")">
                        <td style="white-space: nowrap;">@n.DateSent</td>
                        <td>@n.Message</td>
                        <td>
                            @if (acknowledgedByMe)
                            {
                                <span style="color: var(--accent-green); 
                                             font-size: 12px;">
                                    ● Acknowledged by you
                                </span>
                            }
                            else if (n.IsAcknowledged && 
                                     n.AcknowledgedBy != currentUserID)
                            {
                                <span style="color: var(--text-secondary); 
                                             font-size: 12px;">
                                    ● Acknowledged by others
                                </span>
                            }
                            else
                            {
                                <span style="color: var(--accent-orange); 
                                             font-size: 12px;">
                                    ● Pending
                                </span>
                            }
                        </td>
                        <td>
                            @if (!acknowledgedByMe)
                            {
                                <form method="post"
                                      action="/Notification/Acknowledge"
                                      style="display: inline;">
                                    <input type="hidden"
                                           name="notificationID"
                                           value="@n.NotificationID" />
                                    <button type="submit"
                                            class="btn-success"
                                            style="padding: 4px 12px;
                                                   font-size: 12px;">
                                        Acknowledge
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
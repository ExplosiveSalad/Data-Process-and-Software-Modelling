@{
    ViewData["Title"] = "Enter Diagnosis";
}

@await Html.PartialAsync("_BackButton")

<div class="page-header">
    <div class="page-title">Enter Diagnosis and Treatment Plan</div>
    <div class="page-subtitle">
        Record patient diagnosis and send to Administrative Staff
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
    <div class="card">
        <div class="card-header">Diagnosis Form</div>
        <form method="post">
            <div class="form-group">
                <label class="form-label">Patient</label>
                <select name="patientID" class="form-control" required>
                    <option value="">-- Select Patient --</option>
                    @foreach (var patient in ViewBag.Patients)
                    {
                        <option value="@patient.PatientID">
                            @patient.Name (NHI: @patient.NHINumber)
                        </option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Diagnosis</label>
                <textarea name="diagnosis" class="form-control" 
                          rows="3" required
                          placeholder="Enter clinical diagnosis"></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Treatment Plan</label>
                <textarea name="treatmentPlan" class="form-control" 
                          rows="4" required
                          placeholder="Enter treatment plan"></textarea>
            </div>
            <button type="submit" class="btn-primary">
                Submit Diagnosis
            </button>
            <a href="/Diagnosis/List" 
               class="btn-primary" 
               style="margin-left: 8px;">
                View Records
            </a>
        </form>
    </div>

    <div class="card">
        <div class="card-header">Guidelines</div>
        <div style="color: var(--text-secondary); 
                    font-size: 13px; 
                    line-height: 1.8;">
            <p style="margin-bottom: 12px;">
                Diagnoses and treatment plans are automatically 
                sent to Administrative Staff for processing 
                upon submission.
            </p>
            <div style="padding: 12px; 
                        background-color: var(--bg-secondary);
                        border-radius: 8px;
                        border-left: 3px solid var(--accent-orange);">
                <strong style="color: var(--accent-orange);">FR1</strong><br/>
                Doctors enter diagnoses and treatment plans 
                into the system after clinical assessment.
            </div>
            <div style="padding: 12px; margin-top: 8px;
                        background-color: var(--bg-secondary);
                        border-radius: 8px;
                        border-left: 3px solid var(--accent-blue);">
                <strong style="color: var(--accent-blue);">FR6</strong><br/>
                Approved diagnoses are automatically forwarded 
                to Administrative Staff for deliberation.
            </div>
        </div>
    </div>
</div>
@{
    ViewData["Title"] = "Register Patient";
    @await Html.PartialAsync("_BackButton")
}

<div class="page-header">
    <div class="page-title">Register Patient</div>
    <div class="page-subtitle">
        Create a new patient record or link to existing NHI
    </div>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
        @if (ViewBag.ExistingPatient != null)
        {
            <div style="margin-top: 8px;">
                <strong>Existing Record Found:</strong><br/>
                Name: @ViewBag.ExistingPatient.Name<br/>
                NHI: @ViewBag.ExistingPatient.NHINumber<br/>
                DOB: @ViewBag.ExistingPatient.DateOfBirth
            </div>
        }
    </div>
}

@if (ViewBag.Success != null)
{
    <div class="alert alert-success">@ViewBag.Success</div>
}

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">

    <div class="card">
        <div class="card-header">New Patient Registration</div>
        <form method="post">
            <div class="form-group">
                <label class="form-label">NHI Number</label>
                <input type="text" name="nhiNumber" class="form-control"
                       placeholder="e.g. NHI123456" required />
            </div>
            <div class="form-group">
                <label class="form-label">Full Name</label>
                <input type="text" name="name" class="form-control"
                       placeholder="Enter full name" required />
            </div>
            <div class="form-group">
                <label class="form-label">Date of Birth</label>
                <input type="date" name="dateOfBirth" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">Address</label>
                <input type="text" name="address" class="form-control"
                       placeholder="Enter address" required />
            </div>
            <div class="form-group">
                <label class="form-label">Phone Number</label>
                <input type="text" name="phoneNumber" class="form-control"
                       placeholder="e.g. 021 123 456" required />
            </div>
            <button type="submit" class="btn-primary">Register Patient</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header">Registration Guidelines</div>
        <div style="color: var(--text-secondary); font-size: 13px; line-height: 1.8;">
            <p style="margin-bottom: 12px;">
                Before registering a new patient, always search 
                by NHI number to check for existing records.
            </p>
            <p style="margin-bottom: 12px;">
                <strong style="color: var(--accent-teal);">NHI Number</strong> — 
                The National Health Index number is unique to each patient 
                and is used to link records across the system.
            </p>
            <p style="margin-bottom: 12px;">
                <strong style="color: var(--accent-teal);">Existing Patients</strong> — 
                If a patient already exists, their record will be 
                displayed and linked automatically.
            </p>
            <p>
                <strong style="color: var(--accent-orange);">FR7</strong> — 
                The system links NHI numbers to existing files 
                or creates a new record upon arrival.
            </p>
        </div>

        <div style="margin-top: 20px;">
            <a href="/Patient/Search" class="btn-primary">Search by NHI</a>
            <a href="/Patient/List" 
               style="margin-left: 8px;" 
               class="btn-primary">View All Patients</a>
        </div>
    </div>

</div>
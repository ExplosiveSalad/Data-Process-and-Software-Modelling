<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PATBMS — @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <nav class="navbar">
        <a class="navbar-brand" href="/Dashboard/Index">
            PATBMS <span>Waitakere Hospital</span>
        </a>

        <div style="display: flex; align-items: center; gap: 8px;">
            @if (Context.Session.GetString("UserID") != null)
            {
                var role = Context.Session.GetString("UserRole");

                <a href="/Dashboard/Index" class="nav-link">Dashboard</a>

                @if (role == "admin")
                {
                    <a href="/Patient/Register" class="nav-link">Register Patient</a>
                    <a href="/Patient/Search" class="nav-link">Search NHI</a>
                    <a href="/Patient/List" class="nav-link">Patient List</a>
                    <a href="/Diagnosis/List" class="nav-link">Diagnosis Records</a>
                }

                @if (role == "nurse")
                {
                    <a href="/Patient/List" class="nav-link">Patients</a>
                    <a href="/Triage/Index" class="nav-link">Triage</a>
                    <a href="/Bed/Dashboard" class="nav-link">Bed Dashboard</a>
                    <a href="/Handover/Create" class="nav-link">Handover</a>
                    <a href="/Handover/List" class="nav-link">Handover Records</a>
                    <a href="/Discharge/Index" class="nav-link">Discharge</a>
                    <a href="/Notification/Index" class="nav-link">Alerts</a>
                }

                @if (role == "doctor")
                {
                    <a href="/Patient/List" class="nav-link">Patients</a>
                    <a href="/Triage/Review" class="nav-link">Review Triage</a>
                    <a href="/Bed/Dashboard" class="nav-link">Bed Dashboard</a>
                    <a href="/Bed/Allocate" class="nav-link">Allocate Bed</a>
                    <a href="/Handover/Create" class="nav-link">Handover</a>
                    <a href="/Handover/List" class="nav-link">Handover Records</a>
                    <a href="/Diagnosis/Create" class="nav-link">Diagnosis</a>
                    <a href="/Diagnosis/List" class="nav-link">Diagnosis Records</a>
                }

                @if (role == "management")
                {
                    <a href="/Patient/List" class="nav-link">Patients</a>
                    <a href="/Bed/Dashboard" class="nav-link">Bed Dashboard</a>
                    <a href="/Notification/Index" class="nav-link">Alerts</a>
                }

                @if (role == "allied")
                {
                    <a href="/Patient/List" class="nav-link">Patients</a>
                    <a href="/Discharge/Confirm" class="nav-link">Confirm Discharge</a>
                }

                <span style="color: var(--text-secondary); font-size: 12px; margin-left: 8px;">
                    @Context.Session.GetString("UserName")
                </span>

                <a href="/Account/Logout" class="btn-primary" style="margin-left: 8px;">Logout</a>
            }
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>